{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Posture Monitor System Protocol",
  "description": "Unified protocol definitions for K230 <-> ESP32 UART and ESP32 <-> OneNET MQTT communication",
  "version": "1.0.0",

  "definitions": {
    "PostureType": {
      "type": "string",
      "enum": ["normal", "head_down", "hunchback", "no_person", "unknown"],
      "description": "Posture classification labels shared between K230 and ESP32"
    },

    "FusedPostureTypeCode": {
      "type": "integer",
      "enum": [0, 1, 2, 3],
      "description": "0=no_person, 1=normal, 2=head_down, 3=hunchback"
    },

    "SystemMode": {
      "type": "integer",
      "enum": [0, 1, 2],
      "description": "0=posture, 1=clock, 2=timer"
    },

    "SystemModeName": {
      "type": "string",
      "enum": ["posture", "clock", "timer"],
      "description": "Human-readable system mode names used in App"
    },

    "AlertModeMask": {
      "type": "integer",
      "description": "Bitmask: bit0=LED, bit1=Buzzer, bit2=Voice",
      "minimum": 0,
      "maximum": 7
    },

    "K230UartFrame": {
      "type": "object",
      "description": "Minimal JSON frame sent from K230 to ESP32 via UART",
      "required": ["posture_type"],
      "properties": {
        "posture_type":           { "$ref": "#/definitions/PostureType" }
      }
    },

    "MqttPropertyPost": {
      "type": "object",
      "description": "Properties reported by ESP32 to OneNET via MQTT",
      "properties": {
        "postureType":        { "$ref": "#/definitions/FusedPostureTypeCode" },
        "monitoringEnabled":  { "type": "boolean" },
        "currentMode":        { "$ref": "#/definitions/SystemMode" },
        "personPresent":      { "type": "boolean", "description": "true=person present by PIR/K230 absence gating" },
        "ambientLux":         { "type": "integer", "description": "Ambient light level from BH1750 in lux" },
        "fillLightOn":        { "type": "boolean", "description": "true=fill light GPIO is on" },
        "alertModeMask":      { "$ref": "#/definitions/AlertModeMask" },
        "cooldownMs":         { "type": "integer", "description": "Alert cooldown in milliseconds" },
        "timerDurationSec":   { "type": "integer", "description": "Timer duration in seconds" },
        "timerRunning":       { "type": "boolean" },
        "cfgVersion":         { "type": "integer" },
        "selfTest":           { "type": "boolean" },
        "isPosture":          { "type": "boolean", "description": "Legacy boolean posture field kept only for migration" }
      }
    }
  }
}
