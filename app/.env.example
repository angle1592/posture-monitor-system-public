# OneNET IoT Platform Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

VITE_ONENET_PRODUCT_ID=YOUR_PRODUCT_ID
VITE_ONENET_DEVICE_NAME=YOUR_DEVICE_NAME
VITE_ONENET_TOKEN=YOUR_DEVICE_TOKEN
# Set to true to preview rich realtime/history UI with local mock data.
VITE_USE_MOCK_HISTORY=false
